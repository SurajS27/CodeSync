{
  "manifest_version": 3,
  "name": "CodeSync",
  "version": "0.9.0",
  "description": "Automatically synchronize your coding challenge solutions to GitHub.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://leetcode.com/problems/*",
        "*://*.leetcode.com/problems/*"
      ],
      "js": [
        "content/content_detect.js",
        "content/submission_detector.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
