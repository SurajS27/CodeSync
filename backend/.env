# App Settings
ENV=development
LOG_LEVEL=DEBUG
SECRET_KEY=dev_secret_key_must_be_thirty_two_chars_long_for_security

# Database Configuration (using async psycopg driver)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/codesync

# GitHub OAuth Integration
GITHUB_CLIENT_ID=mock_github_client_id
GITHUB_CLIENT_SECRET=mock_github_client_secret

# Cryptography & JWT Settings
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENCRYPTION_KEY=GgqrKglGu8MxO9YdiQSytkELfhpQkdhacUbqdLYL_7M=
OAUTH_STATE_EXPIRE_MINUTES=10

# Extension Redirect Target
FRONTEND_URL=chrome-extension://mock_chrome_extension_id/options.html
