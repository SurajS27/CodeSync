# App Settings
ENV=development
LOG_LEVEL=INFO
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=placeholder_secret_key_at_least_32_characters_long

# Database Configuration (using async psycopg driver)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/codesync

# GitHub OAuth Integration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Cryptography & JWT Settings
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Generate a valid Fernet key in python: from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())
ENCRYPTION_KEY=placeholder_fernet_encryption_key_base64_32_bytes
OAUTH_STATE_EXPIRE_MINUTES=10

# Extension Redirect Target
FRONTEND_URL=chrome-extension://your_extension_id/options.html
