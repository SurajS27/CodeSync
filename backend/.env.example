# App Settings
ENV=development
LOG_LEVEL=INFO
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=placeholder_secret_key_at_least_32_characters_long

# Database Configuration (using async psycopg driver)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/codesync

# GitHub OAuth Integration (placeholders for next phase)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Chrome Extension Identification
CHROME_EXTENSION_ID=your_chrome_extension_id
